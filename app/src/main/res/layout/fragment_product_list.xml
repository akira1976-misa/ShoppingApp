<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:orientation="vertical">

    <!-- 검색바 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary_color"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_search_box"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_nav_search"
                app:tint="@color/text_secondary"/>

            <EditText
                android:id="@+id/et_search"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@null"
                android:hint="상품명, 브랜드 검색"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:singleLine="true"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="14sp"/>

            <ImageView
                android:id="@+id/btn_search_clear"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_check"
                android:visibility="gone"
                app:tint="@color/text_secondary"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 카테고리 칩 -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:paddingVertical="8dp"
        android:scrollbars="none">
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="12dp"
            app:singleSelection="true"/>
    </HorizontalScrollView>

    <!-- 결과 수 + 필터 + 정렬 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/white"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp">

        <TextView
            android:id="@+id/tv_result_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"/>

        <!-- 필터 버튼 -->
        <LinearLayout
            android:id="@+id/btn_filter"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_page_btn"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_filter"
                app:tint="@color/primary_color"/>

            <TextView
                android:id="@+id/tv_filter_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="필터"
                android:textColor="@color/primary_color"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_filter_badge"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_special_badge"
                android:gravity="center"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- 정렬 버튼 -->
        <LinearLayout
            android:id="@+id/btn_sort"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:background="@drawable/bg_page_btn"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_sort"
                app:tint="@color/primary_color"/>

            <TextView
                android:id="@+id/tv_sort_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="최저가순"
                android:textColor="@color/primary_color"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/divider_color"/>

    <!-- 상품 목록 + 로딩 + 빈 화면 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_products"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="6dp"
            android:clipToPadding="false"/>

        <ProgressBar
            android:id="@+id/progress_list"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:indeterminateTint="@color/primary_color"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tv_empty_state"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="검색 결과가 없습니다."
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:visibility="gone"/>
    </FrameLayout>

    <!-- 페이지네이션 바 -->
    <LinearLayout
        android:id="@+id/pagination_bar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@color/white"
        android:gravity="center"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
            android:id="@+id/btn_prev_page"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_page_btn"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:text="◀ 이전"
            android:textColor="@color/primary_color"
            android:textSize="13sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_page_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="12dp"
            android:text="1 / 1 페이지"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/btn_next_page"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_page_btn_filled"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:text="다음 ▶"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold"/>
    </LinearLayout>
</LinearLayout>
