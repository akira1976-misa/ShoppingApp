<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_main" android:orientation="vertical">
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:background="@color/primary_color" android:gravity="center_vertical" android:paddingHorizontal="16dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="카테고리" android:textColor="@color/white" android:textSize="20sp" android:textStyle="bold"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:orientation="horizontal">
        <ScrollView android:layout_width="95dp" android:layout_height="match_parent"
            android:background="@color/white" android:scrollbars="none">
            <LinearLayout android:id="@+id/main_category_container" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical"/>
        </ScrollView>
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="@color/divider_color"/>
        <ScrollView android:layout_width="110dp" android:layout_height="match_parent"
            android:background="@color/bg_main" android:scrollbars="none">
            <LinearLayout android:id="@+id/mid_category_container" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical"/>
        </ScrollView>
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="@color/divider_color"/>
        <ScrollView android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"
            android:background="@color/white" android:scrollbars="none">
            <LinearLayout android:id="@+id/sub_category_container" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical"/>
        </ScrollView>
    </LinearLayout>
</LinearLayout>
