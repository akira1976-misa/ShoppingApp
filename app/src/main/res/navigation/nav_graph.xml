<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.shopping.pricecompare.ui.HomeFragment"
        android:label="홈"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_productList"
            app:destination="@id/productListFragment" />
        <action
            android:id="@+id/action_home_to_search"
            app:destination="@id/searchFragment" />
    </fragment>

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.shopping.pricecompare.ui.SearchFragment"
        android:label="검색"
        tools:layout="@layout/fragment_search">
        <action
            android:id="@+id/action_search_to_productList"
            app:destination="@id/productListFragment" />
    </fragment>

    <fragment
        android:id="@+id/productListFragment"
        android:name="com.shopping.pricecompare.ui.ProductListFragment"
        android:label="상품 목록"
        tools:layout="@layout/fragment_product_list">
        <argument
            android:name="category"
            android:defaultValue="전체"
            app:argType="string" />
        <argument
            android:name="searchMode"
            android:defaultValue="false"
            app:argType="boolean" />
    </fragment>

</navigation>
